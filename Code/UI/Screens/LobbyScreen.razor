@using Sandbox
@using Sandbox.UI
@using Misk.Presentation
@using Misk.Domain
@namespace Misk.UI
@inherits Panel

<root class="lobby">
	<div class="lobby-panel">
		<div class="lobby-title">War Council</div>
		<div class="lobby-sub">@MapName  —  @ModeLabel</div>

		<div class="seat-list">
			@foreach ( var seat in Game.Seats )
			{
				var canEdit = Game.CanControlSeat( seat );
				<div class="seat-row">
					<div class="seat-name">
						@if ( seat.IsHuman && canEdit )
						{
							@{ if ( !_nameEdits.ContainsKey( seat.PlayerId ) ) _nameEdits[seat.PlayerId] = seat.DisplayName; }
							<TextEntry class="name-input" Value:bind="@_nameEdits[seat.PlayerId]" />
							<span class="name-save" onclick=@(() => RenameSeat( seat ))>✓</span>
						}
						else
						{
							<span>@seat.DisplayName</span>
						}
						@if ( !seat.IsHuman )
						{
							<span class="ai-tag">AI</span>
							@if ( canEdit )
							{
								<span class="ai-diff" onclick=@(() => CycleAi( seat ))>@AiLabel( seat.AiLevel )</span>
							}
						}
					</div>

					<div class="faction-chips">
						@foreach ( var faction in Game.Data.Factions )
						{
							var takenByOther = IsTakenByOther( faction.Id, seat.PlayerId );
							var selected = seat.FactionId == faction.Id;
							var cls = "faction-chip"
								+ (selected ? " selected" : "")
								+ (takenByOther ? " taken" : "");
							<div class="@cls"
								 onclick=@(() => TryPick( seat, faction.Id, canEdit, takenByOther ))>
								@if ( !string.IsNullOrEmpty( faction.SigilPath ) )
								{
									<div class="chip-sigil" style="background-image: url( @faction.SigilPath );"></div>
								}
								else
								{
									<div class="swatch" style="background-color: @faction.Color;"></div>
								}
								<span>@faction.Name</span>
							</div>
						}
					</div>

					@if ( seat.IsHuman )
					{
						<div class="ready-tag @(seat.IsReady ? "is-ready" : "not-ready")"
							 onclick=@(() => ToggleReady( seat, canEdit ))>
							@(seat.IsReady ? "READY" : "NOT READY")
						</div>
					}
					else
					{
						<div class="ready-tag is-ready">AI · READY</div>
					}

					@if ( Game.IsHost && Game.Seats.Count > 2 )
					{
						<div class="seat-remove" onclick=@(() => { MiskAudio.Click(); Game.RequestRemoveSeat( seat.PlayerId ); })>✕</div>
					}
				</div>
			}
		</div>

		@if ( Game.IsHost && Game.Seats.Count < MaxSeats )
		{
			<div class="seat-add-row">
				<div class="add-button" onclick=@(() => { MiskAudio.Click(); Game.RequestAddSeat( true ); })>＋ Add AI</div>
				@if ( Game.IsHotseat )
				{
					<div class="add-button" onclick=@(() => { MiskAudio.Click(); Game.RequestAddSeat( false ); })>＋ Add Player</div>
				}
			</div>
		}

		<div class="lobby-actions">
			<div class="back-button" onclick=@AbandonLobby>Abandon</div>
			@if ( Game.IsHost )
			{
				<div class="start-col">
					<div class="start-button @(CanStart ? "" : "disabled")"
						 onclick=@(() => { if ( CanStart ) { MiskAudio.Click(); Game.RequestStart(); } })>
						March to War
					</div>
					@if ( !CanStart )
					{
						<div class="start-hint">@StartBlockedReason</div>
					}
				</div>
			}
			else
			{
				<div class="waiting">Awaiting the host…</div>
			}
		</div>
	</div>
</root>

@code {
	private MiskGame Game => MiskGame.Current;

	// Per-seat in-progress name edits (committed to the host on ✓). Keyed by seat PlayerId.
	private readonly System.Collections.Generic.Dictionary<string, string> _nameEdits = new();

	private string MapName => Game?.Data?.Map?.Name ?? "Unknown lands";
	private string ModeLabel => Game.IsHotseat ? "Hotseat" : "Online";
	private int MaxSeats => System.Math.Min( 6, Game?.Data?.Factions.Count ?? 6 );

	private string StartBlockedReason
	{
		get
		{
			if ( Game.Seats.Count < 2 )
				return "Two warlords are needed for war.";
			foreach ( var s in Game.Seats )
				if ( string.IsNullOrEmpty( s.FactionId ) )
					return $"{s.DisplayName} has chosen no banner.";
			foreach ( var s in Game.Seats )
				if ( !s.IsReady )
					return $"{s.DisplayName} is not ready.";
			return "";
		}
	}

	private bool IsTakenByOther( string factionId, string seatPlayerId )
	{
		foreach ( var s in Game.Seats )
		{
			if ( s.PlayerId != seatPlayerId && s.FactionId == factionId )
				return true;
		}
		return false;
	}

	private void TryPick( SeatInfo seat, string factionId, bool canEdit, bool takenByOther )
	{
		if ( !canEdit || takenByOther )
			return;
		MiskAudio.Click();
		Game.RequestSetFaction( seat.PlayerId, factionId );
	}

	private void ToggleReady( SeatInfo seat, bool canEdit )
	{
		if ( !canEdit )
			return;
		MiskAudio.Click();
		Game.RequestSetReady( seat.PlayerId, !seat.IsReady );
	}

	private void RenameSeat( SeatInfo seat )
	{
		MiskAudio.Click();
		var name = _nameEdits.TryGetValue( seat.PlayerId, out var n ) ? n : seat.DisplayName;
		Game.RequestSetDisplayName( seat.PlayerId, name );
	}

	private void AbandonLobby()
	{
		MiskAudio.Click();
		UiNav.Confirm( "Abandon the Council?", "The war party will disband and you will return to the main menu.",
			"Abandon", () => Game.ReturnToMenu() );
	}

	private void CycleAi( SeatInfo seat )
	{
		MiskAudio.Click();
		Game.RequestSetAiLevel( seat.PlayerId, ( seat.AiLevel + 1 ) % 3 );
	}

	private static string AiLabel( int level ) => level switch
	{
		0 => "Cautious",
		2 => "Ruthless",
		_ => "Seasoned",
	};

	private bool CanStart
	{
		get
		{
			if ( Game.Seats.Count < 2 )
				return false;
			foreach ( var s in Game.Seats )
			{
				if ( string.IsNullOrEmpty( s.FactionId ) || !s.IsReady )
					return false;
			}
			return true;
		}
	}

	protected override int BuildHash() => Game?.ViewHash ?? 0;
}
