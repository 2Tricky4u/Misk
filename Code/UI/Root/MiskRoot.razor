@using Sandbox
@using Sandbox.UI
@using Misk.Presentation
@using Misk.Domain
@namespace Misk.UI
@inherits PanelComponent

<root class="misk-root">
	<TestReport />
	@if ( Game is null )
	{
		<div class="screen-center"><div class="boot-text">Awakening the realms…</div></div>
	}
	else if ( Game.LoadError is not null )
	{
		<div class="screen-center">
			<div class="error-card">
				<div class="error-title">The atlas is torn</div>
				<div class="error-body">@Game.LoadError</div>
			</div>
		</div>
	}
	else if ( Game.Mode == GameMode.MainMenu )
	{
		<MainMenu />
	}
	else if ( Game.Mode == GameMode.Lobby )
	{
		<LobbyScreen />
	}
	else
	{
		<MapView />
		<RegionInfoPanel />
		<HudBar />
		<CombatLog />
		<CardTray />
		<TurnBanner />
		<FlashLayer />
		@if ( Game.HasPendingAdvance && Game.CanActNow )
		{
			<AdvancePrompt />
		}
		@if ( Game.Mode == GameMode.GameOver || Game.WinnerPlayerId is not null )
		{
			<VictoryOverlay />
		}
	}
	@* In-game pause gear (hidden while an overlay is open or the war is decided). *@
	@if ( Game is not null && Game.Mode == GameMode.InGame && Game.WinnerPlayerId is null && UiNav.Overlay is null )
	{
		<div class="pause-gear" onclick=@(() => { MiskAudio.Click(); UiNav.Show( "pause" ); })>⚙</div>
	}

	@* Modal overlays sit above any mode (pause is in-game only). *@
	@if ( Game is not null )
	{
		@if ( UiNav.Is( "pause" ) && Game.Mode == GameMode.InGame )
		{
			<PauseMenu />
		}
		else if ( UiNav.Is( "settings" ) )
		{
			<SettingsPanel />
		}
		else if ( UiNav.Is( "help" ) )
		{
			<HelpScreen />
		}
	}
</root>

@code {
	private MiskGame Game => MiskGame.Current;

	protected override int BuildHash() => System.HashCode.Combine( Game?.ViewHash ?? 0, UiNav.Overlay );
}
